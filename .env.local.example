# ─── Supabase ──────────────────────────────────────────────────────
# Estate liquidity portal data layer (src/lib/data/) reads these.
# When NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are
# absent the portal automatically falls back to the in-repo demo dataset
# in src/lib/sample-data.ts — no other code paths need to be aware.
#
# To switch to live Supabase mode:
#   1. Fill in the three values below
#   2. Apply  supabase/migrations/0003_estate_liquidity_core.sql
#   3. Optionally seed  supabase/seed/0003_estate_liquidity_seed.sql
#   4. Restart `next dev`
# A subtle "Supabase live" / "Demo data" badge will appear in the
# bottom-right corner during development (or on any page when you append
# `?devbadge=1`).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for write actions (offer accept, disposition,
# stop-sell, payout request, trust-receipt insert, etc.). Never expose
# this to the client bundle — both src/lib/supabase/server.ts and
# src/lib/data/supabase-server.ts are the only readers.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Realtime ──────────────────────────────────────────────────────
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_CLIENT_ID=

# ─── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
