# ─── Supabase ──────────────────────────────────────────────────────
# Estate liquidity portal data layer (src/lib/data/) reads these.
# When NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are
# absent the portal automatically falls back to the in-repo demo dataset
# in src/lib/sample-data.ts — no other code paths need to be aware.
#
# To switch to live Supabase mode:
#   1. Fill in the three values below
#   2. Apply  supabase/migrations/0003_estate_liquidity_core.sql
#   3. Optionally seed  supabase/seed/0003_estate_liquidity_seed.sql
#   4. Restart `next dev`
# A subtle "Supabase live" / "Demo data" badge will appear in the
# bottom-right corner during development (or on any page when you append
# `?devbadge=1`).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for write actions (offer accept, disposition,
# stop-sell, payout request, trust-receipt insert, etc.). Never expose
# this to the client bundle — both src/lib/supabase/server.ts and
# src/lib/data/supabase-server.ts are the only readers.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Realtime ──────────────────────────────────────────────────────
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_CLIENT_ID=

# ─── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Portal security hardening ─────────────────────────────────────
# Server-only. Mixed into IP / user-agent hashes stored in
# audit_events. Without this, the hashes are stable but trivially
# reversible. Generate with `openssl rand -hex 32`.
PORTAL_AUDIT_SALT=
# Comma-separated list of additional origins permitted to call portal
# write routes (used by admin / staging / preview hosts when they live
# on a different domain than the canonical app). The same-origin
# request is always allowed without listing it here.
# Example: PORTAL_TRUSTED_ORIGINS=https://admin.example.com
PORTAL_TRUSTED_ORIGINS=

# ─── Durable rate limiting (optional) ──────────────────────────────
# When BOTH of these are set, the portal write routes use Upstash
# Redis as the rate-limit backing store, sharing buckets across all
# instances. When unset, the platform falls back to an in-memory
# provider (single-instance only — fine for dev / demo previews).
# Both are server-only — never expose them to the client bundle.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics (optional) ──────────────────────────────────────────
# Vendor-neutral event helper at src/lib/analytics.ts dispatches
# `cta_click`, `lead_submitted`, `lead_submit_failed` etc. When no
# vendor adapter is registered the events are no-ops in production.
# Set this to "true" in dev to console.log every event for verification.
NEXT_PUBLIC_ANALYTICS_DEBUG=
# When you add a real vendor (GA4 / PostHog / Plausible / Segment),
# expose its public key here and write a small adapter that registers
# `window.estateAnalytics.send`. No call sites need to change.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_POSTHOG_KEY=
